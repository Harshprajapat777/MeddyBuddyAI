# REQUIRED -- Claude Sonnet 4.6 via byLLM
# Get from https://console.anthropic.com -> Settings -> API Keys.
ANTHROPIC_API_KEY=sk-ant-...

# REQUIRED for the proactive-email demo (send_reminder + caregiver digest)
# 1. Sign up at https://brevo.com (free tier: 300 emails/day).
# 2. Settings -> SMTP & API -> API Keys -> "Generate a new API key", copy it.
BREVO_API_KEY=xkeysib-...

# 3. The "from" address every MeddyBuddy email is sent as.
#    You MUST verify this address in Brevo: Settings -> Senders, Domains &
#    Dedicated IPs -> "Add a sender" -> click the confirmation link Brevo emails
#    you. Otherwise Gmail will dump it straight to spam (SPF/DKIM mismatch).
BREVO_SENDER_EMAIL=meddybuddy@example.com
BREVO_SENDER_NAME=MeddyBuddy

# OPTIONAL -- demo helpers
# Override the LLM model (default: claude-sonnet-4-6). Use "mockllm" to run the
# UI without an Anthropic key -- chat will return canned strings.
# BYLLM_MODEL=mockllm

# Reserved for the future scheduler. 0 = real time, >0 = collapse a "day" to
# N seconds (useful for demoing reminders without waiting hours).
FAST_CLOCK=0
